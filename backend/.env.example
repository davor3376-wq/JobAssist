# Copy this to .env and fill in your values

# Database (Railway will set DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jobassist

# Auth
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Groq (AI - required)
GROQ_API_KEY=gsk_...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Adzuna (Austrian job search) - register at developer.adzuna.com
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key

# Email (choose one)
# Option A: Brevo transactional email API
BREVO_API_KEY=xkeysib-...
EMAILS_FROM_EMAIL=your-email@example.com
EMAILS_FROM_NAME=JobAssist

# Option B: SMTP fallback (used if BREVO_API_KEY is empty)
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# Frontend
FRONTEND_URL=https://jobassist.tech

# CORS - comma-separated or JSON array
ALLOWED_ORIGINS=http://localhost:5173,https://jobassist.tech,https://www.jobassist.tech
# ALLOWED_ORIGINS=["http://localhost:5173","https://jobassist.tech","https://www.jobassist.tech"]

# Example deployed backend
# Railway public URL: https://jobassist-production.up.railway.app

# App
DEBUG=false
LOG_LEVEL=INFO

# Monitoring (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
