# Copy this to .env and fill in your values

# Database (Railway will set DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jobassist

# Auth
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Groq (AI — required)
GROQ_API_KEY=gsk_...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Adzuna (Austrian job search) — register at developer.adzuna.com
ADZUNA_APP_ID=your-app-id
ADZUNA_APP_KEY=your-app-key

# Email / SMTP (for job alert emails)
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=JobAssist <your-email@gmail.com>
SMTP_TLS=true

# CORS — add your Vercel frontend URL
ALLOWED_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# App
DEBUG=false
